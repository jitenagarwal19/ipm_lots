# Browser-visible API base when not using the proxy (development default).
NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"

# Same-origin API proxy — set true in production Docker so the UI calls `/api/backend/*`
# and the Next server forwards to Express with SERVICE_API_KEY (server-side only).
NEXT_PUBLIC_USE_BACKEND_PROXY="false"

# Used only by the Next.js server for `/api/backend/*` proxy and upload rewrites (never expose publicly).
BACKEND_URL="http://localhost:4000"
BACKEND_INTERNAL_URL="http://localhost:4000"
BACKEND_SERVICE_TOKEN="same-as-backend-SERVICE_API_KEY"
