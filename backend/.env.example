# Database Connection
# Use the connection string for your PostgreSQL database.
DATABASE_URL="postgresql://user:password@localhost:5432/ipm_lots?schema=public"

# Optional: Supabase JS client (see db.js) — not used by Prisma; use anon key only on trusted servers.
# SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"

# Redis Configuration (for BullMQ)
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

# API Keys
OPEN_API_KEY="YOUR_OPENAI_API_KEY"

# OpenAI Performance knobs
# Cap the attachment text we send to OpenAI to avoid huge prompts.
OPENAI_MAX_ATTACHMENT_CHARS="45000"

# Frontend Integration
# Production (NODE_ENV=production): comma-separated exact browser origins for CORS.
# Must match the site URL (scheme + host + port), e.g. your Vercel app:
#   FRONTEND_URL="https://ipm-lots.vercel.app"
# Add a custom domain the same way (comma, no spaces unless inside quotes is OK trimmed):
#   FRONTEND_URL="https://ipm-lots.vercel.app,https://app.yourcompany.com"
# Development: CORS allows any Origin so http://192.168.x.x:3000 works with the API on :4000.
FRONTEND_URL="http://localhost:3000"

# Application Settings
PORT="4000"
NODE_ENV="development"

# Optional: append every serverLog line to this file (use when your IDE terminal hides stderr)
# BACKEND_LOG_FILE="./backend-debug.log"

# File Storage Config (Local vs S3)
STORAGE_MODE="local" # 'local' or 's3'
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME="your-bucket-name"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
