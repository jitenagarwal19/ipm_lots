{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:log": "BACKEND_LOG_FILE=./backend-debug.log tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "gmail:auth": "tsx scripts/gmail-auth.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "c8 --check-coverage --lines 80 --statements 80 --branches 64 --functions 75 --all --src src --include \"src/**/*.ts\" --exclude \"src/services/email.ts\" --exclude \"src/worker.ts\" --exclude \"src/index.ts\" --exclude \"**/*.test.ts\" --exclude \"src/test/**\" --exclude \"src/types/**\" --reporter=text-summary tsx --test \"src/**/*.test.ts\"",
    "sanity": "node ../scripts/sanity-check.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@prisma/client": "^5.22.0",
    "@types/uuid": "^10.0.0",
    "bullmq": "^5.76.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "c8": "^11.0.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
