// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lab {
  id        String       @id @default(uuid())
  name      String
  is_active Boolean      @default(true)
  contacts  LabContact[]
  tests     Test[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model LabContact {
  id           String   @id @default(uuid())
  lab_id       String
  lab          Lab      @relation(fields: [lab_id], references: [id])
  contact_name String
  email        String
  is_primary   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id        String   @id @default(uuid())
  name      String
  lots      Lot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Variant {
  id        String   @id @default(uuid())
  name      String
  lots      Lot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id        String   @id @default(uuid())
  name      String
  lots      Lot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vendor {
  id        String   @id @default(uuid())
  name      String
  tests     Test[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id        String   @id @default(uuid())
  name      String
  tests     Test[]   @relation("SampledByStaff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestType {
  id               String   @id @default(uuid())
  name             String
  country_standard String?
  tests            Test[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Lot {
  id         String   @id @default(uuid())
  lot_number String   @unique
  product_id String
  product    Product  @relation(fields: [product_id], references: [id])
  variant_id String?
  variant    Variant? @relation(fields: [variant_id], references: [id])
  company_id String
  company    Company  @relation(fields: [company_id], references: [id])
  tests      Test[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}



model Test {
  id                    String     @id @default(uuid())
  lot_id                String
  lot                   Lot        @relation(fields: [lot_id], references: [id])
  lab_id                String
  lab                   Lab        @relation(fields: [lab_id], references: [id])
  test_type_id          String
  test_type             TestType   @relation(fields: [test_type_id], references: [id])
  vendor_id             String?
  vendor                Vendor?    @relation(fields: [vendor_id], references: [id])
  region                String?
  sampled_by_staff_id   String?
  sampled_by_staff      Staff?     @relation("SampledByStaff", fields: [sampled_by_staff_id], references: [id])
  status                String     @default("INITIATED")
  email_thread_id       String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  emails                Email[]
  labReports            LabReport[]
}

model Email {
  id          String       @id @default(uuid())
  message_id  String       @unique
  thread_id   String?
  subject     String?
  body        String?
  from_email  String
  to_email    String?
  direction   String       @default("RECEIVED")
  received_at DateTime
  test_id     String?
  test        Test?        @relation(fields: [test_id], references: [id])
  attachments Attachment[]
  labReports  LabReport[]
  createdAt   DateTime     @default(now())
}

model Attachment {
  id          String   @id @default(uuid())
  email_id    String
  email       Email    @relation(fields: [email_id], references: [id])
  original_filename String?
  file_url    String   // Local path or S3 URL
  file_type   String?
  extracted_text String?
  labReports LabReport[]
  uploaded_at DateTime @default(now())
}

model LabReport {
  id                         String           @id @default(uuid())
  email_id                   String
  email                      Email            @relation(fields: [email_id], references: [id])
  test_id                    String?
  test                       Test?            @relation(fields: [test_id], references: [id])
  attachment_id              String?
  attachment                 Attachment?      @relation(fields: [attachment_id], references: [id])
  lot_number                 String?
  source_type                String           @default("UNKNOWN")
  source_attachment_filename String?
  status                     String           @default("PENDING_REVIEW")
  metadata_json              String?
  results_json               String?
  raw_ai_json                String
  review_notes               String?
  reviewed_at                DateTime?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  moleculeResults            MoleculeResult[]
}

model MoleculeResult {
  id                      String    @id @default(uuid())
  lab_report_id           String
  labReport               LabReport @relation(fields: [lab_report_id], references: [id])
  molecule_name           String
  cas_number              String?
  result                  String?
  numeric_result          Float?
  unit                    String?
  reporting_limit         String?
  method_detection_limit  String?
  specification_limit     String?
  method                  String?
  status                  String?
  is_detected             Boolean?
  is_compliant            Boolean?
  notes                   String?
  createdAt               DateTime  @default(now())
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AILog {
  id                String   @id @default(uuid())
  message_id        String?
  prompt_sent       String
  response_received String
  createdAt         DateTime @default(now())
}
